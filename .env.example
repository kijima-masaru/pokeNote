APP_NAME=pokeNote
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Docker Compose（nginx の公開ポート。既定 80 → http://localhost）
# 80 が使用中の場合は例: APP_PORT=8000
# APP_PORT=80

# Docker 利用時: compose の php サービスが DB_* を上書き（下記「Docker 用 DB」を参照）
# ホストの MySQL とポートがぶつかる場合は FORWARD_DB_PORT=3307 など

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=poke_note
DB_USERNAME=root
DB_PASSWORD=

# --- Docker Compose（ローカル DB の DB_USERNAME とは別名 MYSQL_APP_* で衝突回避）---
# MYSQL_APP_USER=pokenote
# MYSQL_APP_PASSWORD=secret
# DB_ROOT_PASSWORD=root
# php コンテナでは DB_* が上書きされる（上記に合わせる）
# DB_HOST=mysql
# DB_DATABASE=poke_note
# DB_USERNAME=pokenote
# DB_PASSWORD=secret
# phpMyAdmin: http://localhost:8080
# PMA_PORT=8080

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
